{{def_kernel("A", "B")}}
    # Persistent TLX warp-pipelined bmm for AMD (MI350X / gfx950). C[b] = A[b] @ B[b].
    # Same warp-pipe compute core + addressing as amd_bmm_warppipe, but launched with NUM_SMS
    # programs (1 per CU) that stride over the (batch, m_tile, n_tile) space in a while-loop,
    # reusing the LDS buffers across tiles. This amortizes per-block launch/setup (rocprof: cuts
    # addressing VALU ~40% vs the non-persistent variant) and wins on large-K bmm; the non-
    # persistent variant competes in the same autotune and wins on thin-M/small-tile shapes.
    #
    # NOTE: int32 within-tile offsets (heuristic bounds per-batch M*K, N*K < 2**31); per-batch base
    # advance in int64; (K*itemsize) % 16 == 0 (K % 8 for fp16/bf16; heuristic gate) for a legal direct-to-LDS async_copy; the
    # K % BLOCK_K remainder is a synchronous sync-tail.
    M = {{size("A", -2)}}
    N = {{size("B", -1)}}
    K = {{size("A", -1)}}
    BATCH = {{size("A", 0)}}
    if M * N == 0:
        return
    stride_aq = {{stride("A", 0)}}
    stride_am = {{stride("A", 1)}}
    stride_ak = {{stride("A", 2)}}
    stride_bq = {{stride("B", 0)}}
    stride_bk = {{stride("B", 1)}}
    stride_bn = {{stride("B", 2)}}
    tl.assume(stride_am > 0)
    tl.assume(stride_ak > 0)
    tl.assume(stride_bk > 0)
    tl.assume(stride_bn > 0)

    grid_m = (M + BLOCK_M - 1) // BLOCK_M
    grid_n = (N + BLOCK_N - 1) // BLOCK_N
    grid_mn = grid_m * grid_n
    num_tiles = BATCH * grid_mn
    offs_k = tl.arange(0, BLOCK_K).to(INDEX_DTYPE)
    K_ITERS = K // BLOCK_K
    k_tail = K_ITERS * BLOCK_K
    tail_width = K - k_tail

    smemA = tlx.local_alloc((BLOCK_M, BLOCK_K), tlx.dtype_of(A), NUM_BUFFERS)
    smemB = tlx.local_alloc((BLOCK_K, BLOCK_N), tlx.dtype_of(B), NUM_BUFFERS)

    tile_id = tl.program_id(0).to(INDEX_DTYPE)
    while tile_id < num_tiles:
        batch_id = tile_id // grid_mn
        pid = tile_id % grid_mn
        width = GROUP_M * grid_n
        group_id = pid // width
        group_size = min(grid_m - group_id * GROUP_M, GROUP_M)
        pid_m = group_id * GROUP_M + (pid % group_size)
        pid_n = (pid % width) // group_size
        offs_m = (pid_m * BLOCK_M + tl.arange(0, BLOCK_M).to(INDEX_DTYPE)) % M
        offs_n = (pid_n * BLOCK_N + tl.arange(0, BLOCK_N).to(INDEX_DTYPE)) % N
        batch_i64 = batch_id.to(tl.int64)
        A_b = A + batch_i64 * stride_aq
        B_b = B + batch_i64 * stride_bq
        a_base = offs_m[:, None] * stride_am
        b_base = offs_n[None, :] * stride_bn

        # inter-tile barrier: all warps must finish reading the previous tile's LDS before the
        # prologue below overwrites the reused buffers.
        tl.debug_barrier()

        for i in tl.range(0, NUM_BUFFERS, loop_unroll_factor=NUM_BUFFERS):
            k_start = i * BLOCK_K
            a_offs = a_base + (k_start + offs_k[None, :]) * stride_ak
            b_offs = (k_start + offs_k[:, None]) * stride_bk + b_base
            tok_a = tlx.async_load(A_b + a_offs.to(tl.int32), tlx.local_view(smemA, i))
            tok_b = tlx.async_load(B_b + b_offs.to(tl.int32), tlx.local_view(smemB, i))
            tlx.async_load_commit_group([tok_a, tok_b])

        tlx.async_load_wait_group(NUM_BUFFERS - 2)
        a_tile = tlx.local_load(tlx.local_view(smemA, 0))
        b_tile = tlx.local_load(tlx.local_view(smemB, 0))

        acc = tl.zeros((BLOCK_M, BLOCK_N), dtype=ACC_TYPE)

        for kk in tl.range(0, K_ITERS - NUM_BUFFERS):
            prefetch_buf = (kk % NUM_BUFFERS).to(tl.int32)
            next_buf = ((kk + 1) % NUM_BUFFERS).to(tl.int32)
            k_prefetch = (kk + NUM_BUFFERS) * BLOCK_K

            with tlx.warp_pipeline_stage("mfma", priority=0):
                acc = tl.dot(a_tile, b_tile, acc, allow_tf32=ALLOW_TF32, out_dtype=ACC_TYPE)

            with tlx.warp_pipeline_stage("mem", priority=1):
                a_offs = a_base + (k_prefetch + offs_k[None, :]) * stride_ak
                b_offs = (k_prefetch + offs_k[:, None]) * stride_bk + b_base
                tok_a = tlx.async_load(A_b + a_offs.to(tl.int32), tlx.local_view(smemA, prefetch_buf))
                tok_b = tlx.async_load(B_b + b_offs.to(tl.int32), tlx.local_view(smemB, prefetch_buf))
                tlx.async_load_commit_group([tok_a, tok_b])
                a_tile = tlx.local_load(tlx.local_view(smemA, next_buf))
                b_tile = tlx.local_load(tlx.local_view(smemB, next_buf))

            tlx.async_load_wait_group(NUM_BUFFERS - 2)

        acc = tl.dot(a_tile, b_tile, acc, allow_tf32=ALLOW_TF32, out_dtype=ACC_TYPE)
        tlx.async_load_wait_group(0)
        for i in tl.range(0, NUM_BUFFERS - 1, loop_unroll_factor=NUM_BUFFERS - 1):
            buf = ((K_ITERS - (NUM_BUFFERS - 1) + i) % NUM_BUFFERS).to(tl.int32)
            a_tile = tlx.local_load(tlx.local_view(smemA, buf))
            b_tile = tlx.local_load(tlx.local_view(smemB, buf))
            acc = tl.dot(a_tile, b_tile, acc, allow_tf32=ALLOW_TF32, out_dtype=ACC_TYPE)

        if tail_width > 0:
            a_offs = a_base + (k_tail + offs_k[None, :]) * stride_ak
            a_tail = tl.load(A_b + a_offs.to(tl.int32), mask=offs_k[None, :] < tail_width, other=0.0)
            b_offs = (k_tail + offs_k[:, None]) * stride_bk + b_base
            b_tail = tl.load(B_b + b_offs.to(tl.int32), mask=offs_k[:, None] < tail_width, other=0.0)
            acc = tl.dot(a_tail, b_tail, acc, allow_tf32=ALLOW_TF32, out_dtype=ACC_TYPE)

        rm = pid_m * BLOCK_M + tl.arange(0, BLOCK_M).to(INDEX_DTYPE)
        rn = pid_n * BLOCK_N + tl.arange(0, BLOCK_N).to(INDEX_DTYPE)
        idx_q = batch_id
        idx_m = rm[:, None]
        idx_n = rn[None, :]
        mask = (idx_m < M) & (idx_n < N)
        {{store_output(("idx_q", "idx_m", "idx_n"), "acc", "mask", indent_width=8, val_shape=("BLOCK_M", "BLOCK_N"))}}
        tile_id += NUM_SMS
