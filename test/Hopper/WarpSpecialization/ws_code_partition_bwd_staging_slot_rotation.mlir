// RUN: triton-opt %s --nvgpu-test-ws-code-partition="num-buffers=2" | FileCheck %s

// Regression test for the early-TMA same-partition staging slot rotation
// (bug #10/#11 in .llms/rules/partition-scheduler-bugs.md / D110063164,
// T277224987), exercising getStaggeredAccumCnt in CodePartitionUtility.cpp.
//
// The FA-bwd dv/dk TMA store-staging is SAME-partition: the producer
// (ttg.local_store) and consumer (ttng.async_tma_copy_local_to_global) are both
// the staging task (ttg.partition = 3), drained by a fixed in-flight-count TMA
// store-wait (cp.async.bulk.wait_group K-1, annotated can_rotate_by_buffer_count
// = K = buffer.copy = 2). For that drain to be correct, same-slot stores must be
// exactly K apart in issue order, i.e. the slot must be the per-tile subtile
// index theIdx % K -- NOT the accumCnt-staggered slot used for loop-carried
// buffers (which made consecutive tiles' staggered ranges overlap -> reuse
// distance 1 -> the prior store was clobbered -> wrong dv/dk/dq).
//
// Observable distinction: the staging slot is reduced (divui/muli/subi = modulo
// K) from a CONSTANT subtile index (%cN_i64), with NO dependence on the outer
// loop's accumCnt iter_arg. Loop-carried buffers (m/Di) instead reduce the
// %argNN accumCnt. The fix gates the bare-subtile-index path on same-partition
// staging; cross-partition staging (FA-fwd desc_o) keeps the continuous accumCnt
// so its producer/consumer mbarrier phase keeps rotating (the bug #11 deadlock).
// E2E regression: test_bwd_early_tma_staging_depth2{,_persistent}.

// CHECK-LABEL: @_attn_bwd_persist
// Staging slot = (constant subtile index) % K, in the staging task (3): the
// arith.subi reducing the index takes a CONSTANT (%c...) operand, not the
// loop accumCnt iter_arg.
// CHECK: arith.subi %c{{[0-9_i]+}}, %{{[a-zA-Z0-9_]+}} {ttg.partition = array<i32: 3>} : i64
// The reduced slot indexes the reuse-realized 2x128x64 staging view, and the
// store is drained by the fixed-count K=2 wait in the same staging task.
// CHECK: ttg.memdesc_index %{{[a-zA-Z0-9_]+}}[%{{[a-zA-Z0-9_]+}}] {ttg.partition = array<i32: 3>} : !ttg.memdesc<2x128x64xf16
// CHECK: ttng.async_tma_copy_local_to_global {{.*}} {ttg.partition = array<i32: 3>}
// CHECK: ttng.async_tma_store_token_wait {{.*}} {can_rotate_by_buffer_count = 2 : i32, ttg.partition = array<i32: 3>}

#blocked = #ttg.blocked<{sizePerThread = [1, 8], threadsPerWarp = [2, 16], warpsPerCTA = [4, 1], order = [1, 0]}>
