// RUN: triton-opt %s --nvgpu-test-ws-memory-planner="num-buffers=2 smem-budget=231000" --mlir-print-debuginfo --mlir-use-nameloc-as-prefix 2>&1 | FileCheck %s

// BWD FA persistent kernel (BLOCK_M1=128, EPILOGUE_SUBTILE=2) with TMA
// descriptor_load for M/Di and early_tma_store_lowering for dQ/dK/dV.
//
// Tests buffer reuse in Phase 3.6:
//   - 1D descriptor_load channels (M, Di) are correctly classified as
//     innermost TMA channels (P0) despite being 1D tensors.
//   - dV TMA store staging (buffer.id=20) reuses V's SMEM (buffer.id=3)
//   - dK TMA store staging (buffer.id=22) reuses dO's SMEM (buffer.id=4)
//   - dK and dV staging reuse DIFFERENT targets (claimed-target tracking
//     prevents co-live epilogue buffers from aliasing the same SMEM).
//
// Key verification:
//   - M (Di) buffers get allocated=1 (not reused — they're innermost P0)
//   - dV staging gets allocation.shareGroup (reuses V)
//   - dK staging gets allocation.shareGroup (reuses dO, NOT V)

// Remarks: reuse decisions with named buffers (emitted to stderr before IR)
// CHECK: remark: SMEM buffer "desc_dv_staging" (buffer.id=20, 16384B) reuses "v" (buffer.id=3)
// CHECK: remark: SMEM buffer "desc_dk_staging" (buffer.id=22, 16384B) reuses "do" (buffer.id=4)

// Di gets double-buffered (P0 innermost TMA, no allocation.shareGroup)
// CHECK: %Di = ttg.local_alloc {buffer.copy = 2 : i32, buffer.id = 12 : i32}

// m stays single-buffered (budget can only fit one P0 double-buffer)
// CHECK: %m = ttg.local_alloc {buffer.copy = 1 : i32, buffer.id = 14 : i32}

// dV staging: reuses V (allocation.shareGroup = 20, different from dK)
// CHECK: ttg.local_alloc {allocation.reuseTarget = 3 : i32, allocation.shareGroup = 20 : i32, buffer.copy = 2 : i32, buffer.id = 20 : i32, buffer.tmaStaging = 1 : i32}

// dK staging: reuses dO, NOT V (allocation.shareGroup = 22)
// CHECK: ttg.local_alloc {allocation.reuseTarget = 4 : i32, allocation.shareGroup = 22 : i32, buffer.copy = 2 : i32, buffer.id = 22 : i32, buffer.tmaStaging = 1 : i32}

#blocked = #ttg.blocked<{sizePerThread = [1, 8], threadsPerWarp = [2, 16], warpsPerCTA = [4, 1], order = [1, 0]}>
#blocked1 = #ttg.blocked<{sizePerThread = [1], threadsPerWarp = [32], warpsPerCTA = [4], order = [0]}>
#blocked2 = #ttg.blocked<{sizePerThread = [1, 4], threadsPerWarp = [2, 16], warpsPerCTA = [4, 1], order = [1, 0]}>
