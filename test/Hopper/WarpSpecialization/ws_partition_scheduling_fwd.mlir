// RUN: triton-opt %s --nvgpu-partition-scheduling-meta 2>&1 | FileCheck %s
// Test: FA FWD non-persistent partition scheduling.
// Must match persistent FWD: gemm → partition 1, load → partition 2,
// epilogue(descriptor_store only) → partition 3,
// computation(mulf/exp2 on 2D tensor) → partition 4 or 5.
// Epilogue must NOT contain heavy computation.

// CHECK-LABEL: tt.func public @_attn_fwd
// CHECK-DAG: ttng.tc_gen5_mma {{.*}}ttg.partition = 1
// CHECK-DAG: tt.descriptor_load {{.*}}ttg.partition = 2
// CHECK-DAG: arith.mulf {{.*}}ttg.partition = 5{{.*}}tensor<128x128xf32
// CHECK-DAG: math.exp2 {{.*}}ttg.partition = 5{{.*}}tensor<128x128xf32
// CHECK-DAG: tt.descriptor_store {{.*}}ttg.partition = 3
// Verify no heavy ops in epilogue (partition 3)
// CHECK-NOT: math.exp2 {{.*}}ttg.partition = 3
// CHECK-NOT: arith.divf {{.*}}ttg.partition = 3
// CHECK-NOT: ttng.tmem_load {{.*}}ttg.partition = 3

#blocked = #ttg.blocked<{sizePerThread = [1, 128], threadsPerWarp = [32, 1], warpsPerCTA = [4, 1], order = [0, 1]}>
