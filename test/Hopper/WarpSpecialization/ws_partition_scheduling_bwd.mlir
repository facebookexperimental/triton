// RUN: triton-opt %s --nvgpu-partition-scheduling-meta 2>&1 | FileCheck %s
// Test: FA BWD partition scheduling.
// gemm → partition 1, load → partition 2, computation(exp2/mulf 2D) → partition 3,
// epilogue(descriptor_store) → partition 3, reduction(mulf 128x32) → partition 0.

// CHECK-LABEL: tt.func public @_attn_bwd
// CHECK-DAG: ttng.tc_gen5_mma {{.*}}ttg.partition = 1
// CHECK-DAG: tt.descriptor_load {{.*}}ttg.partition = 2
// CHECK-DAG: math.exp2 {{.*}}ttg.partition = 3{{.*}}tensor<128x128xf32
// CHECK-DAG: arith.mulf {{.*}}ttg.partition = 3{{.*}}tensor<128x128xf32
// CHECK-DAG: tt.descriptor_store {{.*}}ttg.partition = 3
// CHECK-DAG: arith.mulf {{.*}}ttg.partition = 0{{.*}}tensor<128x32xf32

