// RUN: triton-opt %s --nvgpu-ws-data-partition=num-warp-groups=3 | FileCheck %s
//
// Test that the data partition pass handles FA backward correctly:
// - 5 dots: qkT(S), dpT(dP), dV, dQ, dK, all 128x128
// - dQ output goes exclusively to descriptor_reduce (atomic add)
// - dK and dV are loop-carried accumulators
// - K/V local_alloc are outer-loop free variables used by inner-loop dots
// - With data_partition_factor=2, the pass should:
//   1. Partition qkT, dpT, dV, dK dots along dim 0 (K/V sliced to 64x128)
//   2. dQ gets noOpPartitionDim (K-slice detected, output goes to atomic stores)
//   3. Partitioned dots produce 64x128 output
//
// CHECK-LABEL: @_attn_bwd_persist
// K and V are sliced to 64x128 (two partitions of the 128x128 alloc)
// CHECK: ttg.local_alloc {{.*}} -> !ttg.memdesc<64x128xf16
// CHECK: ttg.local_alloc {{.*}} -> !ttg.memdesc<64x128xf16
// Partitioned dots (qkT) produce 64x128 output
// CHECK: ttng.warp_group_dot {{.*}} -> tensor<64x128xf32
// The pass completes without errors
#blocked = #ttg.blocked<{sizePerThread = [1, 4], threadsPerWarp = [4, 8], warpsPerCTA = [4, 1], order = [1, 0]}>
#blocked1 = #ttg.blocked<{sizePerThread = [1], threadsPerWarp = [32], warpsPerCTA = [4], order = [0]}>
#blocked2 = #ttg.blocked<{sizePerThread = [1, 8], threadsPerWarp = [2, 16], warpsPerCTA = [4, 1], order = [1, 0]}>
#blocked3 = #ttg.blocked<{sizePerThread = [1, 2, 4], threadsPerWarp = [4, 1, 8], warpsPerCTA = [4, 1, 1], order = [1, 2, 0]}>
#blocked4 = #ttg.blocked<{sizePerThread = [1, 4, 2], threadsPerWarp = [4, 8, 1], warpsPerCTA = [4, 1, 1], order = [2, 1, 0]}>
#blocked5 = #ttg.blocked<{sizePerThread = [1, 8], threadsPerWarp = [8, 4], warpsPerCTA = [4, 1], order = [1, 0]}>
#linear = #ttg.linear<{register = [[0, 1], [8, 0], [0, 8], [0, 16], [64, 0]], lane = [[0, 2], [0, 4], [1, 0], [2, 0], [4, 0]], warp = [[16, 0], [32, 0]], block = []}>
#linear1 = #ttg.linear<{register = [[1, 0], [0, 8], [8, 0], [16, 0], [32, 0], [64, 0], [0, 64]], lane = [[2, 0], [4, 0], [0, 1], [0, 2], [0, 4]], warp = [[0, 16], [0, 32]], block = []}>
#linear2 = #ttg.linear<{register = [[0, 64], [0, 32], [0, 1], [0, 2], [16, 0], [32, 0], [64, 0]], lane = [[0, 4], [0, 8], [0, 16], [1, 0], [2, 0]], warp = [[4, 0], [8, 0]], block = []}>
#linear3 = #ttg.linear<{register = [[0, 1, 0], [0, 0, 32], [0, 0, 1], [0, 0, 2], [16, 0, 0], [32, 0, 0], [64, 0, 0]], lane = [[0, 0, 4], [0, 0, 8], [0, 0, 16], [1, 0, 0], [2, 0, 0]], warp = [[4, 0, 0], [8, 0, 0]], block = []}>
#linear4 = #ttg.linear<{register = [[0, 0, 1], [0, 32, 0], [0, 1, 0], [0, 2, 0], [16, 0, 0], [32, 0, 0], [64, 0, 0]], lane = [[0, 4, 0], [0, 8, 0], [0, 16, 0], [1, 0, 0], [2, 0, 0]], warp = [[4, 0, 0], [8, 0, 0]], block = []}>
