// CHECK-DAG: tt.descriptor_load {{.*}}ttg.partition = 2
// CHECK-DAG: arith.mulf {{.*}}ttg.partition = 5{{.*}}tensor<128x128xf32
// CHECK-DAG: math.exp2 {{.*}}ttg.partition = 5{{.*}}tensor<128x128xf32
// CHECK-DAG: tt.descriptor_store {{.*}}ttg.partition = 3

